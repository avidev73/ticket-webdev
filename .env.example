# Copy this file to .env and fill in the values

# Google Gemini API key — create one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Optional: which Gemini model to use (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-pro

# Slack Incoming Webhook URL for your dev team channel
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Password for the /admin page (username can be anything)
ADMIN_PASSWORD=change-me

# Public URL of this app (used to build clickable attachment links in Slack).
# Only needed for LOCAL runs — on Vercel, Blob storage handles links automatically.
APP_URL=

# Port to listen on (local only)
PORT=3000

# --- Set automatically by Vercel, do not fill in locally ---
# DATABASE_URL=            (added by the Neon/Postgres integration)
# BLOB_READ_WRITE_TOKEN=   (added by the Blob store integration)
