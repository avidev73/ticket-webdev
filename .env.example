# Copy this file to .env and fill in the values

# Anthropic API key — https://platform.claude.com/ (or log in with `ant auth login` and leave unset)
ANTHROPIC_API_KEY=sk-ant-...

# Slack Incoming Webhook URL for your dev team channel
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Password for the /admin page (username can be anything)
ADMIN_PASSWORD=change-me

# Public URL of this app (used to build clickable attachment links in Slack).
# Leave empty when running only on localhost.
APP_URL=

# Port to listen on
PORT=3000
